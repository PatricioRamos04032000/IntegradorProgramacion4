extends ../layout

block content
  .container.mt-4
    h1= title
    
    //- Si el controlador atrapa un error de regla de negocio, lo mostramos acá
    if error
      .alert.alert-danger.alert-dismissible.fade.show(role="alert")
        strong ¡Error de Validación! 
        span= error
        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")

    .card.shadow-sm
      .card-body
        form(action='/inscripciones', method='POST')
          .row.mb-3
            .col-md-6
              label.form-label(for='id_estudiante') Estudiante
              select#id_estudiante.form-select(name='id_estudiante', required)
                option(value='', disabled, selected) Seleccione un estudiante...
                if estudiantes && estudiantes.length > 0
                  each estudiante in estudiantes
                    option(value=estudiante.id_estudiante) #{estudiante.apellido}, #{estudiante.nombres} (#{estudiante.documento})
                else 
                  option(disabled) No hay estudiantes activos.
            
            .col-md-6
              label.form-label(for='id_curso') Curso
              select#id_curso.form-select(name='id_curso', required)
                option(value='', disabled, selected) Seleccione un curso...
                if cursos && cursos.length > 0
                  each curso in cursos
                    //- Mostramos el nombre y el cupo para guiar al usuario visualmente
                    option(value=curso.id_curso) #{curso.nombre} (Cupo Máx: #{curso.inscriptos_max})
                else
                  option(disabled) No hay cursos activos.

          .d-flex.justify-content-end.mt-4
            a.btn.btn-secondary.me-2(href='/inscripciones') Cancelar
            button.btn.btn-primary(type='submit') Confirmar Inscripción