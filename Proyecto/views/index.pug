extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold Panel de Gestión
    span.text-muted Fecha: #{new Date().toLocaleDateString()}

  //- Tarjetas de Totales
  .row.mb-5
    .col-md-6.mb-3
      .card.text-white.bg-primary.shadow-sm.h-100.border-0.curso-card
        .card-body.p-4.d-flex.justify-content-between.align-items-center
          div
            h6.text-uppercase.fw-bold.mb-1 Cursos Activos
            h2.display-4.fw-bold.mb-0= totalCursos
          i.bi.bi-journal-check.display-1.opacity-50
        .card-footer.bg-transparent.border-0.text-end
          a.text-white.text-decoration-none(href='/cursos') Ver todos ➔

    .col-md-6.mb-3
      .card.text-white.bg-success.shadow-sm.h-100.border-0.curso-card
        .card-body.p-4.d-flex.justify-content-between.align-items-center
          div
            h6.text-uppercase.fw-bold.mb-1 Estudiantes
            h2.display-4.fw-bold.mb-0= totalEstudiantes
          i.bi.bi-people.display-1.opacity-50
        .card-footer.bg-transparent.border-0.text-end
          a.text-white.text-decoration-none(href='/estudiantes') Ver todos ➔

  //- Sección de Cursos en formato Tarjetas
  h4.mb-3.fw-bold ⚡ Últimos Cursos Añadidos
  .row.g-4
    if cursosRapidos && cursosRapidos.length > 0
      each curso in cursosRapidos
        .col-md-6.col-xl-4
          .card.h-100.shadow-sm.border-0.curso-card
            .card-body
              .d-flex.justify-content-between.align-items-start.mb-2
                h5.card-title.fw-bold.text-dark= curso.nombre
                span.badge.bg-info.rounded-pill Cupo: #{curso.inscriptos_max}
              p.card-text.text-muted.small Ideal para potenciar tu perfil profesional en el área de sistemas.
            .card-footer.bg-transparent.border-0.pt-0
              a.btn.btn-outline-primary.btn-sm.w-100(href=`/cursos/${curso.id_curso}`) Gestionar Curso
    else
      .col-12
        .alert.alert-secondary No hay cursos activos para mostrar.