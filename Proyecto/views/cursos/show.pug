extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-3
    h1.h3.mb-0= curso.nombre
    div
      a.btn.btn-secondary.me-2(href='/cursos') Volver
      a.btn.btn-primary.me-2(href='/cursos/' + curso.id_curso + '/editar') Editar
      form.d-inline(method='post', action='/cursos/' + curso.id_curso + '?_method=DELETE', onsubmit="return confirm('¿Eliminar este curso?');")
        button.btn.btn-danger(type='submit') Eliminar

  .card.shadow-sm
    .card-body
      dl.row.mb-0
        dt.col-sm-3 Estado
        dd.col-sm-9
          span.badge.bg-secondary= curso.estado

        dt.col-sm-3 Fecha de inicio
        dd.col-sm-9= curso.fecha_inicio ? new Date(curso.fecha_inicio).toLocaleDateString('es-AR') : '-'

        dt.col-sm-3 Cantidad de horas
        dd.col-sm-9= curso.cantidad_horas

        dt.col-sm-3 Inscriptos máximos
        dd.col-sm-9= curso.inscriptos_max

        dt.col-sm-3 Descripción
        dd.col-sm-9= curso.descripcion

        dt.col-sm-3 Última modificación
        dd.col-sm-9
          | #{curso.fecha_hora_modificacion ? new Date(curso.fecha_hora_modificacion).toLocaleString('es-AR') : '-'}
          |  · usuario ##{curso.id_usuario_modificacion}
