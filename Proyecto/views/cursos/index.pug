extends ../layout

block content
  h2.mb-3 Listado de Cursos

  .fcad-card.mb-3
    form.row.g-2(method='get', action='/cursos')
      .col-lg-5
        label.form-label(for='q') Buscar por nombre
        input#q.form-control(type='text', name='q', value=filtros.q, placeholder='Ingrese parte del nombre...')
      .col-lg-4
        label.form-label(for='estado') Estado
        select#estado.form-select(name='estado')
          option(value='') Todos
          each est in estados
            option(value=est.id_curso_estado, selected=(String(est.id_curso_estado) === String(filtros.estado)))
              = est.descripcion
      .col-lg-3.d-flex.align-items-end
        button.btn.btn-outline-primary.w-100(type='submit') Filtrar

  if resultado.items.length === 0
    .alert.alert-info No se encontraron cursos para los filtros aplicados.
  else
    .fcad-card
      .table-responsive
        table.table.table-striped
          thead
            tr
              th ID
              th Nombre
              th Descripción
              th.text-center Inicio
              th.text-center Cantidad de Horas
              th.text-center Máx. Cant. Inscriptos
              th.text-center Estado
              th.text-center.fcad-acciones Acciones
          tbody
            each curso in resultado.items
              tr
                td= curso.id_curso
                td= curso.nombre
                td= curso.descripcion
                td.text-center= curso.fecha_inicio ? new Date(curso.fecha_inicio).toLocaleDateString('es-AR') : '-'
                td.text-center= curso.cantidad_horas
                td.text-center= curso.inscriptos_max
                td.text-center
                  span.badge.bg-secondary= curso.estado
                td.text-center.fcad-acciones
                  .btn-group.btn-group-sm(role='group')
                    a.btn.btn-outline-primary(href='/cursos/' + curso.id_curso) Ver
                    a.btn.btn-outline-secondary(href='/cursos/' + curso.id_curso + '/editar') Editar
                    form.d-inline(method='post', action='/cursos/' + curso.id_curso + '?_method=DELETE', onsubmit="return confirm('¿Eliminar este curso?');")
                      button.btn.btn-outline-danger(type='submit') Eliminar

      .d-flex.justify-content-between.align-items-center.mt-3
        small.text-muted
          | Mostrando página #{resultado.page} de #{resultado.totalPages} (#{resultado.total} resultado#{resultado.total === 1 ? '' : 's'})
        ul.pagination.mb-0
          - var qs = (filtros.q ? '&q=' + encodeURIComponent(filtros.q) : '') + (filtros.estado ? '&estado=' + encodeURIComponent(filtros.estado) : '') + (filtros.pageSize ? '&pageSize=' + filtros.pageSize : '')
          li.page-item(class=(resultado.page <= 1 ? 'disabled' : ''))
            a.page-link(href='/cursos?page=' + (resultado.page - 1) + qs) Anterior
          li.page-item.disabled
            span.page-link= resultado.page + ' / ' + resultado.totalPages
          li.page-item(class=(resultado.page >= resultado.totalPages ? 'disabled' : ''))
            a.page-link(href='/cursos?page=' + (resultado.page + 1) + qs) Siguiente

  .d-flex.justify-content-end.mt-3
    a.btn.btn-secondary(href='/cursos/nuevo') + Nuevo Curso
