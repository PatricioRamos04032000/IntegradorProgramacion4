extends ../layout

block content
  .container.mt-4
    .d-flex.justify-content-between.align-items-center.mb-4
      h1= title
      a.btn.btn-primary(href='/estudiantes/nuevo') Agregar Estudiante

    //- Buscador
    form(action='/estudiantes', method='GET', class='mb-4')
      .input-group
        input.form-control(type='text', name='q', value=searchQuery, placeholder='Buscar por apellido o documento...')
        button.btn.btn-outline-secondary(type='submit') Buscar
        if searchQuery
          a.btn.btn-outline-danger(href='/estudiantes') Limpiar

    //- Tabla BROWSE
    .table-responsive
      table.table.table-striped.table-hover
        thead.table-dark
          tr
            th Documento
            th Apellido
            th Nombres
            th Email
            th Acciones
        tbody
          if estudiantes.length > 0
            each estudiante in estudiantes
              tr
                td= estudiante.documento
                td= estudiante.apellido
                td= estudiante.nombres
                td= estudiante.email
                td
                  //- Acciones BREAD
                  a.btn.btn-sm.btn-info.me-2(href=`/estudiantes/${estudiante.id_estudiante}`) Ver
                  a.btn.btn-sm.btn-warning.me-2(href=`/estudiantes/${estudiante.id_estudiante}/editar`) Editar
                  
                  //- Botón Delete usando method-override
                  form(action=`/estudiantes/${estudiante.id_estudiante}?_method=DELETE`, method='POST', class='d-inline', onsubmit="return confirm('¿Estás seguro de eliminar este estudiante?');")
                    button.btn.btn-sm.btn-danger(type='submit') Borrar
          else
            tr
              td(colspan="5", class="text-center") No se encontraron estudiantes activos.

    //- Paginación
    if estudiantes.length > 0
      nav(aria-label='Navegación de páginas')
        ul.pagination.justify-content-center
          li.page-item(class=(page == 1 ? 'disabled' : ''))
            a.page-link(href=`/estudiantes?page=${page - 1}&q=${searchQuery}&pageSize=${pageSize}`) Anterior
          
          li.page-item.active
            span.page-link Página #{page}
            
          li.page-item(class=(estudiantes.length < pageSize ? 'disabled' : ''))
            a.page-link(href=`/estudiantes?page=${page + 1}&q=${searchQuery}&pageSize=${pageSize}`) Siguiente