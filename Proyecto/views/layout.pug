doctype html
html(lang='es')
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    title= title || 'Sistema de Gestión - FCAD'
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css')
    link(rel='stylesheet', href='/stylesheets/style.css')
    
  body.bg-light
    .d-flex.min-vh-100
      //- ==========================================
      //- SIDEBAR (Solo visible en pantallas grandes)
      //- ==========================================
      aside.sidebar.shadow-sm.d-none.d-md-flex.flex-column.p-3
        //- Logo / Título
        a.navbar-brand.fw-bold.d-flex.align-items-center(href='/')
          img(src='/img/Instagram-CON-LOGO-fcad.png', alt='FCAD - UNER Logo', class='me-2 img-fluid', style='height: 4rem;')
        hr
        ul.nav.nav-pills.flex-column.mb-auto
          li.nav-item
            a.nav-link(href='/') 
              i.bi.bi-grid-1x2-fill.me-2
              | Panel de Inicio
          li.nav-item
            a.nav-link(href='/inscripciones') 
              i.bi.bi-card-checklist.me-2
              | Inscripciones
          li.nav-item
            a.nav-link(href='/estudiantes') 
              i.bi.bi-people-fill.me-2
              | Estudiantes
          li.nav-item
            a.nav-link(href='/cursos') 
              i.bi.bi-journal-bookmark-fill.me-2
              | Cursos
        hr
        //- Info del usuario (Para cuando implementemos JWT)
        .dropdown
          a.d-flex.align-items-center.text-light.text-decoration-none(href='#')
            i.bi.bi-person-circle.fs-4.me-2.text-secondary
            strong Usuario Admin

      //- ==========================================
      //- CONTENIDO PRINCIPAL Y HEADER MÓVIL
      //- ==========================================
      .flex-grow-1.d-flex.flex-column.overflow-hidden
        
        //- Navbar móvil (Visible solo en celulares)
        header.d-md-none.sidebar-mobile.text-white.p-3.shadow-sm.d-flex.justify-content-between.align-items-center
          span.fs-5.fw-bold FCAD - UNER
          button.btn.btn-primary.border-white(type='button', data-bs-toggle='offcanvas', data-bs-target='#mobileMenu')
            i.bi.bi-list.fs-4

        //- Menú Offcanvas para celulares
        #mobileMenu.offcanvas.offcanvas-start(tabindex='-1')
          .offcanvas-header
            h5.offcanvas-title Menú FCAD
            button.btn-close(type='button', data-bs-dismiss='offcanvas')
          .offcanvas-body
            .list-group.list-group-flush
              a.list-group-item.list-group-item-action(href='/') Panel de Inicio
              a.list-group-item.list-group-item-action(href='/inscripciones') Inscripciones
              a.list-group-item.list-group-item-action(href='/estudiantes') Estudiantes
              a.list-group-item.list-group-item-action(href='/cursos') Cursos

        //- Contenedor donde se inyectan las vistas
        main.p-4.flex-grow-1
          block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')