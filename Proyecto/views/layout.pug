doctype html
html(lang='es')
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    title= title
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='/stylesheets/style.css')
  body.fcad-body
    header.fcad-header
      .fcad-header-contenedor
        h1.fcad-titulo Cursos FCAD - UNER
        span.fcad-subtitulo Sistema de Inscripción

    .fcad-contenedor-principal
      nav.fcad-nav
        ul
          li
            a(href='/') Inicio
          li
            a(href='/inscripciones') Inscripciones
          li
            a(href='/estudiantes') Estudiantes
          li
            a(href='/cursos') Cursos
      main.fcad-main
        .container-fluid.py-4
          block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
